generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id               BigInt           @id @default(autoincrement())
  cart_id          BigInt
  variant_id       BigInt
  quantity         Int
  carts            carts            @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, variant_id], map: "cart_items_cart_id_product_id_key")
  @@index([cart_id], map: "idx_cart_items_cart")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model carts {
  id         BigInt       @id @default(autoincrement())
  user_id    String       @unique
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  cart_items cart_items[]
}

model categories {
  id               BigInt       @id @default(autoincrement())
  name             String
  parent_id        BigInt?
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id               BigInt  @id @default(autoincrement())
  order_id         BigInt
  product_id       BigInt?
  quantity         Int
  unit_price_cents Int
  orders           orders  @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id          BigInt        @id @default(autoincrement())
  user_id     Int?
  status      order_status  @default(created)
  total_cents Int
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  order_items order_items[]

  @@index([user_id], map: "idx_orders_user")
}

model product_cards {
  id              BigInt   @id @default(autoincrement())
  product_id      BigInt
  variant_id      BigInt   @unique
  product_name    String
  variant_name    String?
  category_id     BigInt?
  price_cents     Int
  stock_quantity  Int
  image_url       String
  specs           Json?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  variant_options Json?
}

model product_images {
  id               BigInt            @id @default(autoincrement())
  product_id       BigInt?
  url              String
  variant_id       BigInt?
  position         Int?              @db.SmallInt
  products         products?         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onDelete: NoAction)
}

model product_specs {
  id         BigInt   @id @default(autoincrement())
  product_id BigInt
  key        String
  value      String?
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model product_variants {
  id              BigInt            @id @default(autoincrement())
  product_id      BigInt
  variant_name    String?
  price_cents     Int
  stock_quantity  Int               @default(0)
  cart_items      cart_items[]
  product_images  product_images[]
  products        products          @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variant_options variant_options[]
  wishlist_items  wishlist_items[]

  @@index([product_id], map: "idx_product_variants_product_id")
  @@index([variant_name], map: "idx_product_variants_variant_name")
}

model products {
  id               BigInt             @id @default(autoincrement())
  name             String
  description      String?
  category_id      BigInt?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  product_images   product_images[]
  product_specs    product_specs[]
  product_variants product_variants[]
  categories       categories?        @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  reviews          reviews[]
  wishlist_items   wishlist_items[]

  @@index([category_id], map: "idx_products_category")
  @@index([name], map: "idx_products_name")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model reviews {
  id                Int                 @id @default(autoincrement())
  user_id           String
  product_id        BigInt
  rating            Int                 @db.SmallInt
  comment           String?
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  products          products            @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviews_reactions reviews_reactions[]

  @@unique([user_id, product_id])
  @@index([product_id], map: "idx_reviews_product")
}

model reviews_reactions {
  id         BigInt    @id(map: "reviews_rections_pkey") @default(autoincrement())
  user_id    String?
  comment_id Int?
  type       liketype?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  reviews    reviews?  @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model variant_options {
  id               BigInt           @id @default(autoincrement())
  variant_id       BigInt
  key              String
  value            String
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model wishlist {
  id             Int              @id @default(autoincrement())
  user_id        String           @unique
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  wishlist_items wishlist_items[]

  @@index([user_id], map: "idx_wishlist_user_id")
}

model wishlist_items {
  id               Int               @id @default(autoincrement())
  wishlist_id      Int
  product_id       BigInt?
  variant_id       BigInt?
  added_at         DateTime?         @default(now()) @db.Timestamp(6)
  products         products?         @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onUpdate: NoAction)
  wishlist         wishlist          @relation(fields: [wishlist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([wishlist_id, product_id, variant_id])
  @@index([product_id], map: "idx_wishlist_items_product_id")
  @@index([wishlist_id], map: "idx_wishlist_items_wishlist_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model coupons {
  id               Int       @id @default(autoincrement())
  coupon_code      String    @unique
  description      String?
  discount_amount  Decimal?  @db.Decimal(10, 2)
  discount_percent Int?
  max_usage        Int?      @default(1)
  times_used       Int?      @default(0)
  valid_from       DateTime? @default(now()) @db.Timestamptz(6)
  expires_at       DateTime? @db.Timestamptz(6)

  @@index([coupon_code], map: "idx_coupon_code")
}

enum liketype {
  like
  dislike
}

enum order_status {
  created
  paid
  shipped
  delivered
  cancelled
}

enum user_role {
  user
  admin
}
